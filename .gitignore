# Playground .gitignore
# This file defines what is project-specific (generated by AI) vs framework (tracked in git)

# ============================================================================
# GENERATED FILES (project-specific, not tracked)
# ============================================================================

# Nested dependency install — created locally by setup.mjs (local-dev only).
# Keeps deps out of the host repo even if this folder itself is tracked.
/node_modules/
# Lockfile from the nested Bun install — intentionally not committed (local-dev only).
/bun.lock
/bun.lockb
# npm lockfile is redundant here — the project standardizes on Bun (see setup.mjs).
/package-lock.json

# Generated iteration files - AI creates these when iterating on components
iterations/*.iteration-*.tsx
iterations/iterations-images/*

# Generated API routes for component-specific data fetching
# AI creates these when a component needs live data (e.g., api/insights/route.ts)

previews/

# Discovery manifest — AI-generated per-project, not tracked
discovery.json
data/*.mockData.ts
canvas-components/*
!canvas-components/.gitkeep

skills/

# Eval harness run artifacts (per-run, not tracked)
evals/runs/

# ============================================================================
# FRAMEWORK FILES (tracked in git)
# ============================================================================
# The following are explicitly NOT ignored (they are the playground framework):
#
# - page.tsx                    Entry point
# - PlaygroundClient.tsx        Main client component
# - PlaygroundCanvas.tsx        ReactFlow canvas
# - PlaygroundSidebar.tsx       Component sidebar
# - registry.tsx                Types, helpers, empty registry template
# - nodes/                      Node components (ComponentNode, IterationNode)
# - docs/                       AI instructions and documentation
# - iterations/index.ts         Template for iteration registration
# - server/routes/iterations.ts Core API for managing iterations
