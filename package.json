{
  "name": "design-playground",
  "version": "0.0.0",
  "private": true,
  "description": "Local-dev design playground. Its dependencies install NESTED under src/app/playground/node_modules (via setup.mjs) so the host project's package.json and lockfile are never touched. Local-dev only — never built in CI/prod. Vite-compatible. react/react-dom/tailwindcss are provided by the host (peerDependencies).",
  "dependencies": {
    "@hono/node-server": "^1.19.14",
"@radix-ui/react-accordion": "^1.2.13",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-dropdown-menu": "^2.1.17",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tailwindcss/typography": "^0.5.20",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "hono": "^4.12.27",
    "html-to-image": "^1.11.13",
    "lucide-react": "^1.17.0",
    "react-router-dom": "^7.0.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zustand": "^5.0.14"
  },
  "peerDependencies": {
    "react": "^18 || ^19",
    "react-dom": "^18 || ^19",
    "tailwindcss": "^4",
    "vite": "^5 || ^6"
  }
}
